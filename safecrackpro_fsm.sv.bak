module safecrack_pro #(
    parameter int CLK_FREQ = 50_000_000,
    parameter logic [3:0] SECRET_PASS [0:3] = '{4'd1, 4'd2, 4'd3, 4'd4}
)(
    input  logic        clk,
    input  logic [3:0]  KEY,
    output logic [6:0]  HEX0,
    output logic [6:0]  HEX1,
    output logic [6:0]  HEX2,
    output logic [6:0]  HEX3,
    output logic [6:0]  HEX4,
    output logic [8:0]  LEDG,
    output logic [17:0] LEDR
);

    localparam logic [31:0] TIME_5SEC = CLK_FREQ * 5;
    localparam logic [31:0] TIME_3SEC = CLK_FREQ * 3;
    localparam int DEBOUNCE_COUNT = CLK_FREQ / 50; // 20 ms

    typedef enum logic [2:0] {
        INITIAL,
        WAIT_BUTTON,
        VERIFY,
        SUCCESS,
        FAIL
    } state_t;

    state_t state, next_state;

    logic [3:0] user_pass [0:3];
    logic [3:0] next_user_pass [0:3];

    logic [1:0] idx, next_idx;

    logic [31:0] timer, next_timer;

    logic rstn;
    assign rstn = KEY[0];

    logic [3:1] key_sync0;
    logic [3:1] key_sync1;
    logic [3:1] key_db;

    logic [$clog2(DEBOUNCE_COUNT)-1:0] db_counter [3:1];

    logic [3:1] key_pos;
    logic [3:1] key_prev;
    logic [3:1] key_edge;

    logic dec_btn;
    logic inc_btn;
    logic confirm_btn;

    assign dec_btn     = key_edge[3];
    assign inc_btn     = key_edge[2];
    assign confirm_btn = key_edge[1];

    integer i;

    always_ff @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            key_sync0 <= 3'b111;
            key_sync1 <= 3'b111;
            key_db    <= 3'b111;

            for (i = 1; i <= 3; i = i + 1) begin
                db_counter[i] <= '0;
            end
        end else begin
            key_sync0 <= KEY[3:1];
            key_sync1 <= key_sync0;

            for (i = 1; i <= 3; i = i + 1) begin
                if (key_sync1[i] == key_db[i]) begin
                    db_counter[i] <= '0;
                end else begin
                    if (db_counter[i] == DEBOUNCE_COUNT - 1) begin
                        key_db[i] <= key_sync1[i];
                        db_counter[i] <= '0;
                    end else begin
                        db_counter[i] <= db_counter[i] + 1'b1;
                    end
                end
            end
        end
    end

    always_comb begin
        key_pos  = ~key_db;
        key_edge = key_pos & ~key_prev;
    end

    always_ff @(posedge clk or negedge rstn) begin
        if (!rstn) begin
            state    <= INITIAL;
            idx      <= 2'd0;
            timer    <= 32'd0;
            key_prev <= 3'b000;

            user_pass[0] <= 4'd0;
            user_pass[1] <= 4'd0;
            user_pass[2] <= 4'd0;
            user_pass[3] <= 4'd0;
        end else begin
            state    <= next_state;
            idx      <= next_idx;
            key_prev <= key_pos;

            if (state != next_state)
                timer <= 32'd0;
            else
                timer <= next_timer;

            user_pass <= next_user_pass;
        end
    end

    always_comb begin
        next_state     = state;
        next_idx       = idx;
        next_timer     = timer;
        next_user_pass = user_pass;

        case (state)

            INITIAL: begin
                next_idx = 2'd0;
                next_user_pass = '{4'd0, 4'd0, 4'd0, 4'd0};
                next_state = WAIT_BUTTON;
            end

            WAIT_BUTTON: begin
                if (inc_btn) begin
                    if (user_pass[idx] == 4'd9)
                        next_user_pass[idx] = 4'd0;
                    else
                        next_user_pass[idx] = user_pass[idx] + 4'd1;
                end

                else if (dec_btn) begin
                    if (user_pass[idx] == 4'd0)
                        next_user_pass[idx] = 4'd9;
                    else
                        next_user_pass[idx] = user_pass[idx] - 4'd1;
                end

                else if (confirm_btn) begin
                    if (idx < 2'd3)
                        next_idx = idx + 2'd1;
                    else
                        next_state = VERIFY;
                end
            end

            VERIFY: begin
                if ((user_pass[0] == SECRET_PASS[0]) &&
                    (user_pass[1] == SECRET_PASS[1]) &&
                    (user_pass[2] == SECRET_PASS[2]) &&
                    (user_pass[3] == SECRET_PASS[3])) begin
                    next_state = SUCCESS;
                end else begin
                    next_state = FAIL;
                end
            end

            SUCCESS: begin
                if (timer < TIME_5SEC - 1) begin
                    next_timer = timer + 32'd1;
                end else begin
                    next_state = INITIAL;
                end
            end

            FAIL: begin
                if (timer < TIME_3SEC - 1) begin
                    next_timer = timer + 32'd1;
                end else begin
                    next_state = INITIAL;
                end
            end

            default: begin
                next_state = INITIAL;
            end

        endcase
    end

    logic [3:0] active_digit_val;

    always_comb begin
        LEDG = 9'b0;
        LEDR = 18'b0;
        active_digit_val = 4'hF;

        case (state)
            WAIT_BUTTON: active_digit_val = {2'b00, idx};
            SUCCESS:     LEDG = 9'h1FF;
            FAIL:        LEDR = 18'h3FFFF;
            default:     active_digit_val = 4'hF;
        endcase
    end

    function automatic logic [6:0] sseg_decode(input logic [3:0] num);
        case (num)
            4'd0: sseg_decode = 7'b1000000;
            4'd1: sseg_decode = 7'b1111001;
            4'd2: sseg_decode = 7'b0100100;
            4'd3: sseg_decode = 7'b0110000;
            4'd4: sseg_decode = 7'b0011001;
            4'd5: sseg_decode = 7'b0010010;
            4'd6: sseg_decode = 7'b0000010;
            4'd7: sseg_decode = 7'b1111000;
            4'd8: sseg_decode = 7'b0000000;
            4'd9: sseg_decode = 7'b0010000;
            default: sseg_decode = 7'b1111111;
        endcase
    endfunction

    assign HEX3 = sseg_decode(user_pass[0]);
    assign HEX2 = sseg_decode(user_pass[1]);
    assign HEX1 = sseg_decode(user_pass[2]);
    assign HEX0 = sseg_decode(user_pass[3]);
    assign HEX4 = sseg_decode(active_digit_val);

endmodule